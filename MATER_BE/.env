# .env.example
# Copy this file to `.env` and set real values before running

# Flask Settings
SECRET_KEY=super-secret-key
APP_SETTINGS=common.base.DevelopmentConfig   # or ProductionConfig / TestingConfig
DATABASETYPE=sqlite                      # postgresql | mysql | sqlite

# Database Settings
DB_USERNAME=mater_user
DB_PASSWORD=mater_pass
DB_HOST=localhost
DB_NAME=mater_db
